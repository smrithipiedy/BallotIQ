rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anonymous users to read/write their own session data
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null && (request.auth.uid == sessionId || request.resource.data.sessionId == sessionId);
      
      match /context/{id} {
        allow read, write: if request.auth != null && request.auth.uid == sessionId;
      }
      match /progress/{id} {
        allow read, write: if request.auth != null && request.auth.uid == sessionId;
      }
      match /messages/{id} {
        allow read, write: if request.auth != null && request.auth.uid == sessionId;
      }
    }
    
    // Rate limits - allow update but prevent tampering with counts from other sessions
    match /rate_limits/{sessionId} {
      allow read: if request.auth != null && request.auth.uid == sessionId;
      allow write: if request.auth != null && request.auth.uid == sessionId;
    }

    // AI Content Caches
    match /guides_cache/{docId} {
      allow read: if true;
      allow write: if request.auth != null && (!resource.data.keys().hasAll(['expiresAt']) || request.time > resource.data.expiresAt);
    }

    match /quizzes_cache/{docId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
