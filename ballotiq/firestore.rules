rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anonymous users to read/write their own session data
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null && (request.auth.uid == sessionId || request.resource.data.sessionId == sessionId);
      
      // Nested collections for history and progress
      match /{allPaths=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Allow reading public caches
    match /cache/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Rate limits - allow update but prevent tampering with counts from other sessions
    match /rateLimits/{sessionId} {
      allow read: if request.auth != null && request.auth.uid == sessionId;
      allow write: if request.auth != null && request.auth.uid == sessionId;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
